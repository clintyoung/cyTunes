# =============================================================================
# cyTunes environment variables
# Copy this file to .env on your ZimaOS host. NEVER commit .env to git.
# =============================================================================

# --- App ---
# Public URL the app is served at. Must match what Spotify and Cloudflare expect.
APP_URL=https://cytunes.yourcompany.today

# Random 32+ byte string. Generate with: openssl rand -base64 48
SESSION_SECRET=replace_me_with_a_long_random_string

# Port the Next.js container listens on internally (don't change unless you know why)
PORT=3000

# --- Postgres ---
POSTGRES_USER=cytunes
POSTGRES_PASSWORD=replace_me_with_a_strong_password
POSTGRES_DB=cytunes
# Internal connection string the web container uses to reach the db container
DATABASE_URL=postgres://cytunes:replace_me_with_a_strong_password@db:5432/cytunes

# --- Spotify ---
# From https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=c9283a0be7e44e07a2aceebcaf25fb10
SPOTIFY_CLIENT_SECRET=replace_me_rotate_the_one_you_pasted_in_chat
# Must exactly match the redirect URI registered in the Spotify dashboard
SPOTIFY_REDIRECT_URI=https://cytunes.yourcompany.today/api/auth/callback/spotify

# --- GetSongBPM ---
# From https://getsongbpm.com/api (free, requires attribution link in footer)
GETSONGBPM_API_KEY=replace_me_rotate_the_one_you_pasted_in_chat

# --- Cloudflare Tunnel ---
# Token from Cloudflare Zero Trust dashboard. Looks like a very long base64 string.
CLOUDFLARED_TUNNEL_TOKEN=replace_me_from_cloudflare_zero_trust_dashboard
